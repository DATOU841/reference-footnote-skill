.DS_Store
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Never commit real article task data or runtime outputs.
state/
tasks/
task-data/
formal-tasks/
real-tasks/
runtime/
outputs/
delivery/
test-results/
dist/
*.docx
*.pdf
*.zip

# Claude review is produced after the pre-release review step.
.handoff/claude/*-review.md
!.handoff/claude/.gitkeep
